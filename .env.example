# Copy this to .env for local development
# On Railway, set these as environment variables in the dashboard

FLASK_SECRET_KEY=your-secret-key-here

# Xero OAuth — leave as placeholder if not using Xero
XERO_CLIENT_ID=your-xero-client-id
XERO_CLIENT_SECRET=your-xero-client-secret
# Update to your Railway domain for production:
XERO_REDIRECT_URI=http://localhost:5050/xero/callback

# Local dev uses SQLite. Railway auto-sets DATABASE_URL to a PostgreSQL URL.
DATABASE_URL=sqlite:///warehouse.db
